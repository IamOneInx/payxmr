# Copy this to .env and fill in your values
# Never commit .env to git

# Basic auth for the wallet-rpc HTTP endpoint.
# Format: username:password
# Use a strong random password — this protects your transaction history.
RPC_LOGIN=payxmr:changeme

# Password used when your view-only wallet file was created.
# If you created it with no password, leave this empty.
WALLET_PASSWORD=
